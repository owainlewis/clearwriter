<%
  total_docs = Current.user.documents.count

  # Which resource "tab" is active, so its sidebar header highlights. Tags
  # filter documents, so they count as the Documents tab.
  docs_active = %w[documents tags].include?(controller_name)
  collections_active = %w[collections collection_documents].include?(controller_name)
  tasks_active = %w[tasks task_comments task_documents].include?(controller_name)
  tag_counts = Current.user.documents
    .where("array_length(tags, 1) > 0")
    .pluck(:tags)
    .flatten
    .tally
    .sort_by { |_, c| [ -c, _ ] }
    .first(10)
%>

<div data-controller="sidebar">
  <%# When collapsed, a small floating button appears so the user can bring the sidebar back. %>
  <button type="button"
          class="app-sidebar-show"
          data-action="sidebar#toggle"
          data-sidebar-target="toggle"
          aria-label="Show sidebar"
          aria-expanded="true"
          title="Show sidebar">☰</button>

  <aside class="app-sidebar">
    <div class="app-sidebar__top">
      <%= link_to "PAIR", documents_path, class: "app-sidebar__brand" %>
      <div class="app-sidebar__top-actions">
        <%= button_to documents_path, method: :post,
              form_class: "app-sidebar__icon-form",
              class: "app-sidebar__icon-btn",
              title: "New document",
              "aria-label": "New document" do %>
          <%= icon :plus %>
        <% end %>
        <button type="button"
                class="app-sidebar__icon-btn"
                data-action="sidebar#toggle"
                aria-label="Hide sidebar"
                title="Hide sidebar">⇤</button>
      </div>
    </div>

    <%# No per-resource lists here on purpose: Documents and Collections can
        each grow large, so their index pages are the place to browse them. %>
    <section class="app-sidebar__section">
      <%= link_to documents_path, class: "app-sidebar__tab #{'app-sidebar__tab--active' if docs_active}" do %>
        <%= icon :document, class: "app-sidebar__tab-icon" %>
        <span class="app-sidebar__tab-label">Documents</span>
        <span class="app-sidebar__tab-count"><%= total_docs %></span>
      <% end %>
      <%= link_to tasks_path, class: "app-sidebar__tab #{'app-sidebar__tab--active' if tasks_active}" do %>
        <%= icon :board, class: "app-sidebar__tab-icon" %>
        <span class="app-sidebar__tab-label">Tasks</span>
        <span class="app-sidebar__tab-count"><%= Current.user.tasks.count %></span>
      <% end %>
      <%= link_to collections_path, class: "app-sidebar__tab #{'app-sidebar__tab--active' if collections_active}" do %>
        <%= icon :collection, class: "app-sidebar__tab-icon" %>
        <span class="app-sidebar__tab-label">Collections</span>
        <span class="app-sidebar__tab-count"><%= Current.user.collections.count %></span>
      <% end %>
    </section>

    <% if tag_counts.any? %>
      <section class="app-sidebar__section">
        <div class="app-sidebar__section-label">
          <%= icon :tag, class: "app-sidebar__section-label-icon" %> Tags
        </div>
        <ul class="app-sidebar__list">
          <% tag_counts.each do |tag, count| %>
            <li>
              <%= link_to documents_path(tag: tag, since: "all"), class: "app-sidebar__tag" do %>
                <span class="app-sidebar__tag-name">#<%= tag %></span>
                <span class="app-sidebar__tag-count"><%= count %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <nav class="app-sidebar__bottom">
      <%= link_to "Settings", settings_api_tokens_path, class: "app-sidebar__bottom-link" %>
      <%= button_to "Sign out", sign_out_path, method: :delete, class: "app-sidebar__bottom-link app-sidebar__signout" %>
    </nav>
  </aside>
</div>
