<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "PAIR" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Apply persisted sidebar-collapsed class before paint to avoid a flash. %>
    <script>
      (function () {
        try {
          if (localStorage.getItem("cw:sidebar-collapsed") === "1") {
            document.documentElement.classList.add("app-shell-collapsed-boot");
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="<%= authenticated? ? 'app-shell' : 'app-shell--plain' %>"
        <%= 'data-controller="shortcuts"'.html_safe if authenticated? %>>
    <% if authenticated? %>
      <%= render "layouts/sidebar" %>
      <main class="app-main"><%= yield %></main>

      <%# Hidden targets for the global "new" keyboard shortcuts (n d / n t / n c). %>
      <%= form_with url: documents_path, method: :post, class: "cw-hidden",
            data: { shortcuts_target: "document" } do %><% end %>
      <%= form_with url: tasks_path, scope: :task, method: :post, class: "cw-hidden",
            data: { shortcuts_target: "task" } do |f| %>
        <%= f.hidden_field :title, value: "" %>
        <%= f.hidden_field :status, value: "todo" %>
      <% end %>
      <%= form_with url: collections_path, scope: :collection, method: :post, class: "cw-hidden",
            data: { shortcuts_target: "collection" } do |f| %>
        <%= f.hidden_field :name, value: "" %>
      <% end %>
    <% else %>
      <main class="app-main app-main--plain"><%= yield %></main>
    <% end %>
  </body>
</html>
