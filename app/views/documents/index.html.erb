<div class="cw-page cw-page--wide">
  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <div class="cw-page__header">
    <h1 class="cw-page__title">Documents</h1>
  </div>

  <% current_since = params[:since].presence || "7d" %>
  <% current_view = params[:view] == "grid" ? "grid" : "list" %>
  <nav class="cw-filters">
    <span class="cw-segmented" aria-label="Filter by date">
      <% [["7d", "Last 7 days"], ["30d", "Last 30 days"], ["all", "All"]].each do |val, label| %>
        <% active = current_since == val %>
        <%= link_to label, documents_path(since: val, tag: @tag, view: current_view),
              class: "cw-segmented__item #{'cw-segmented__item--active' if active}",
              "aria-current": ("page" if active) %>
      <% end %>
    </span>
    <% if @tag %>
      <%= link_to documents_path(since: current_since, view: current_view), class: "cw-chip cw-chip--tag cw-chip--removable" do %>
        <%= @tag %><span class="cw-chip__remove" aria-hidden="true">×</span>
      <% end %>
    <% end %>

    <span class="cw-view-toggle" aria-label="Document view">
      <%= link_to documents_path(since: current_since, tag: @tag, view: "list"),
            class: "cw-view-toggle__item #{'cw-view-toggle__item--active' if current_view == 'list'}",
            title: "List view",
            "aria-label": "List view",
            "aria-current": ("page" if current_view == "list") do %>
        <%= icon :list %>
      <% end %>
      <%= link_to documents_path(since: current_since, tag: @tag, view: "grid"),
            class: "cw-view-toggle__item #{'cw-view-toggle__item--active' if current_view == 'grid'}",
            title: "Grid view",
            "aria-label": "Grid view",
            "aria-current": ("page" if current_view == "grid") do %>
        <%= icon :grid %>
      <% end %>
    </span>
  </nav>

  <% if @documents.empty? %>
    <p class="cw-empty">No documents in this view. Try “All” or create one.</p>
  <% elsif current_view == "grid" %>
    <div class="cw-doc-grid">
      <% @documents.each do |document| %>
        <%= link_to edit_document_path(document), class: "cw-doc-card" do %>
          <span class="cw-doc-card__title #{'cw-doc-card__title--untitled' if document.title.blank?}">
            <%= document.title.presence || "Untitled" %>
          </span>
          <span class="cw-doc-card__excerpt"><%= truncate(document_card_excerpt(document), length: 190, separator: " ") %></span>
          <span class="cw-doc-card__meta">
            <span><%= document.updated_at.strftime("%b %-d") %></span>
            <% if document.tags.any? %>
              <span class="cw-doc-card__tags">
                <% document.tags.first(3).each do |tag| %>
                  <span class="cw-chip cw-chip--tag"><%= tag %></span>
                <% end %>
              </span>
            <% end %>
          </span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <ul class="cw-doc-list">
      <% @documents.each do |document| %>
        <li class="cw-doc-list__item">
          <%= link_to edit_document_path(document), class: "cw-doc-list__row" do %>
            <span class="cw-doc-list__title #{'cw-doc-list__title--untitled' if document.title.blank?}">
              <%= icon :document, class: "cw-doc-list__icon" %> <%= document.title.presence || "Untitled" %>
            </span>
            <span class="cw-doc-list__date"><%= document.updated_at.strftime("%b %-d") %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
