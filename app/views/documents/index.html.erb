<div class="cw-page cw-page--wide">
  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <div class="cw-page__header">
    <h1 class="cw-page__title">Documents</h1>
    <%= button_to "New document", documents_path, method: :post, class: "cw-btn cw-btn--primary" %>
  </div>

  <% current_since = params[:since].presence || "7d" %>
  <nav class="cw-filters">
    <% [["7d", "Last 7 days"], ["30d", "Last 30 days"], ["all", "All"]].each do |val, label| %>
      <% active = current_since == val %>
      <%= link_to label, documents_path(since: val, tag: @tag),
            class: "cw-chip #{'cw-chip--active' if active}" %>
    <% end %>
    <% if @tag %>
      <span style="margin-left: 8px; color: var(--cw-muted);">Tag:</span>
      <%= link_to "#{@tag} ✕", documents_path(since: current_since), class: "cw-chip cw-chip--active" %>
    <% end %>
  </nav>

  <% if @documents.empty? %>
    <p class="cw-empty">No documents in this view. Try “All” or create one.</p>
  <% else %>
    <ul class="cw-doc-list">
      <% @documents.each do |document| %>
        <li class="cw-doc-list__item">
          <div class="cw-doc-list__main">
            <%= link_to (document.title.presence || "Untitled"), edit_document_path(document),
                  class: "cw-doc-list__title #{'cw-doc-list__title--untitled' if document.title.blank?}" %>
            <% if document.tags.any? %>
              <div class="cw-doc-list__tags">
                <% document.tags.each do |t| %>
                  <%= link_to t, documents_path(tag: t, since: current_since), class: "cw-chip cw-chip--tag" %>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="cw-doc-list__meta">
            <span><%= document.updated_at.strftime("%b %-d") %></span>
            <%= button_to "Delete", document_path(document), method: :delete,
                  data: { turbo_confirm: "Delete this document?" },
                  class: "cw-btn cw-btn--danger" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
