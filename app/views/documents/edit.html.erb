<div data-controller="editor"
     data-editor-url-value="<%= document_path(@document) %>"
     data-editor-preview-url-value="<%= preview_document_path(@document) %>"
     class="cw-editor">

  <div class="cw-editor__bar">
    <span class="cw-editor__bar-spacer"></span>

    <div class="cw-editor__bar-right">
      <span class="cw-status-dot"
            data-editor-target="status"
            data-state="saved"
            title="Saved"
            aria-label="Save status"></span>

      <details class="cw-menu">
        <summary class="cw-menu__trigger" aria-label="Document actions">⋯</summary>
        <div class="cw-menu__panel" role="menu">
          <% if @document.is_public %>
            <%= button_to "Unshare", document_share_path(@document), method: :delete,
                  class: "cw-menu__item" %>
          <% else %>
            <%= button_to "Share publicly", document_share_path(@document), method: :post,
                  class: "cw-menu__item" %>
          <% end %>
          <%= button_to "Delete document", document_path(@document), method: :delete,
                data: { turbo_confirm: "Delete this document? This cannot be undone." },
                class: "cw-menu__item cw-menu__item--danger" %>
        </div>
      </details>
    </div>
  </div>

  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <% if @document.is_public %>
    <div class="cw-public-url">
      <span class="cw-public-url__label">Public</span>
      <a class="cw-public-url__link" href="<%= public_document_url(@document.public_token) %>" target="_blank">
        <%= public_document_url(@document.public_token) %>
        <span class="cw-public-url__arrow">↗</span>
      </a>
    </div>
  <% end %>

  <%= form_with model: @document, class: "contents" do |form| %>
    <%= form.text_field :tags_text,
          placeholder: "tags, comma, separated",
          value: @document.tags_text,
          data: { editor_target: "tags" },
          class: "cw-editor__tags" %>

    <div data-editor-target="editorPane" class="cw-editor__host">
      <%= form.text_area :body,
            rows: 24,
            data: { editor_target: "textarea" },
            placeholder: "# Start with a heading…" %>
    </div>

    <div data-editor-target="previewPane" class="preview-host hidden"></div>

    <%# Manual Save is the no-JS fallback; the editor controller hides it on connect. %>
    <div style="margin-top: 16px; display: flex; justify-content: flex-end;" data-editor-target="fallbackSave">
      <%= form.submit "Save", class: "cw-btn cw-btn--primary" %>
    </div>
  <% end %>
</div>
