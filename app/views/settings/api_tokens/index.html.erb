<div class="cw-page">
  <div class="cw-page__header">
    <h1 class="cw-page__title">API tokens</h1>
    <%= link_to "← Documents", documents_path, class: "cw-back-link" %>
  </div>

  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <% if @new_token %>
    <div class="cw-token-banner">
      <p style="margin: 0 0 4px; font-weight: 500;">Copy this token now — it won't be shown again.</p>
      <code class="cw-token-banner__code"><%= @new_token %></code>
    </div>
  <% end %>

  <%= form_with url: settings_api_tokens_path, method: :post, class: "cw-token-form" do |form| %>
    <%= form.text_field :name, placeholder: "Token name (optional)", class: "cw-token-form__input" %>
    <%= form.submit "Create token", class: "cw-btn cw-btn--primary" %>
  <% end %>

  <% if @api_tokens.empty? %>
    <p class="cw-empty">No tokens yet.</p>
  <% else %>
    <ul class="cw-token-list">
      <% @api_tokens.each do |token| %>
        <li class="cw-token-list__item">
          <div>
            <div class="cw-token-list__name"><%= token.name.presence || "Unnamed" %></div>
            <div class="cw-token-list__meta">
              Created <%= token.created_at.strftime("%b %-d, %Y") %>
              <% if token.last_used_at %>· last used <%= time_ago_in_words(token.last_used_at) %> ago<% end %>
            </div>
          </div>
          <%= button_to "Revoke", settings_api_token_path(token), method: :delete,
                data: { turbo_confirm: "Revoke this token?" },
                class: "cw-btn cw-btn--danger" %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <div class="cw-curl">
    <div class="cw-curl__label">Using your token</div>
<pre>curl -H "Authorization: Bearer pair_..." https://usepair.ai/api/v1/documents

curl -X PUT -H "Authorization: Bearer pair_..." \
  -H "Content-Type: text/markdown" \
  --data-binary @notes.md \
  https://usepair.ai/api/v1/documents/&lt;token&gt;/content</pre>
  </div>
</div>
