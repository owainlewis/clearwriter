<div class="cw-page cw-page--wide" data-controller="reveal" data-action="keydown@window->reveal#close">
  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <div class="cw-page__header cw-page__header--detail">
    <span></span>
    <%= button_to collection_path(@collection), method: :delete,
          form: { data: { turbo_confirm: "Delete this collection? The documents are kept." } },
          form_class: "cw-icon-btn-form",
          class: "cw-icon-btn cw-icon-btn--danger",
          title: "Delete collection",
          "aria-label": "Delete collection" do %>
      <%= icon :trash %>
    <% end %>
  </div>

  <div class="cw-detail-title">
    <%= icon :collection, class: "cw-detail-title__icon" %>
    <h1 class="cw-detail-title__text"><%= @collection.display_name %></h1>
    <button type="button" class="cw-btn cw-btn--ghost cw-btn--sm"
            data-reveal-target="trigger" data-action="reveal#toggle">Rename</button>
  </div>
  <p class="cw-detail-meta"><%= pluralize(@documents.size, "document") %></p>

  <%= form_with url: collection_path(@collection), scope: :collection, method: :patch,
        class: "cw-form-card cw-hidden", data: { reveal_target: "panel" } do |f| %>
    <%= f.text_field :name, value: @collection.name, placeholder: Collection::NAME_FALLBACK,
          class: "cw-input cw-input--title", required: true, data: { reveal_target: "field" } %>
    <%= f.submit "Save", class: "cw-btn cw-btn--primary" %>
    <button type="button" class="cw-btn cw-btn--ghost" data-action="reveal#toggle">Cancel</button>
  <% end %>

  <% current_view = params[:view] == "grid" ? "grid" : "list" %>
  <section class="cw-section">
    <div class="cw-section__head">
      <h2 class="cw-section__title">Documents</h2>
      <span class="cw-view-toggle" aria-label="Collection document view">
        <%= link_to collection_path(@collection, view: "list"),
              class: "cw-view-toggle__item #{'cw-view-toggle__item--active' if current_view == 'list'}",
              title: "List view",
              "aria-label": "List view",
              "aria-current": ("page" if current_view == "list") do %>
          <%= icon :list %>
        <% end %>
        <%= link_to collection_path(@collection, view: "grid"),
              class: "cw-view-toggle__item #{'cw-view-toggle__item--active' if current_view == 'grid'}",
              title: "Grid view",
              "aria-label": "Grid view",
              "aria-current": ("page" if current_view == "grid") do %>
          <%= icon :grid %>
        <% end %>
      </span>
    </div>

    <%= render "shared/document_picker",
          search_url: search_collection_documents_path(@collection),
          placeholder: "Search documents to add…" %>

    <% if @documents.any? %>
      <% if current_view == "grid" %>
        <div id="linked-docs" class="cw-doc-grid">
          <% @documents.each do |document| %>
            <div id="linked-doc-<%= document.public_token %>" class="cw-doc-card-wrap">
              <%= link_to edit_document_path(document), class: "cw-doc-card" do %>
                <span class="cw-doc-card__title #{'cw-doc-card__title--untitled' if document.title.blank?}">
                  <%= document.title.presence || "Untitled" %>
                </span>
                <span class="cw-doc-card__excerpt"><%= truncate(document_card_excerpt(document), length: 190, separator: " ") %></span>
                <span class="cw-doc-card__meta">
                  <span><%= document.updated_at.strftime("%b %-d") %></span>
                  <% if document.tags.any? %>
                    <span class="cw-doc-card__tags">
                      <% document.tags.first(3).each do |tag| %>
                        <span class="cw-chip cw-chip--tag"><%= tag %></span>
                      <% end %>
                    </span>
                  <% end %>
                </span>
              <% end %>
              <%= button_to collection_document_path(@collection, document), method: :delete,
                    class: "cw-card-remove",
                    form_class: "cw-card-action",
                    title: "Unlink document",
                    "aria-label": "Unlink document" do %>
                <%= icon :close %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <ul id="linked-docs" class="cw-doc-list">
          <% @documents.each do |document| %>
            <%= render "shared/linked_document", document: document,
                  unlink_url: collection_document_path(@collection, document) %>
          <% end %>
        </ul>
      <% end %>
    <% end %>
    <p id="linked-docs-empty" class="cw-empty" <%= "hidden" if @documents.any? %>>No documents in this collection yet.</p>
  </section>
</div>
