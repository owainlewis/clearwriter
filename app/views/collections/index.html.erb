<div class="cw-page cw-page--wide" data-controller="dialog">
  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <div class="cw-page__header">
    <h1 class="cw-page__title">Collections</h1>
    <button type="button"
            class="cw-create-btn"
            data-action="dialog#open"
            title="New collection (press n then c)"
            aria-label="New collection">
      <span class="cw-create-btn__disc"><%= icon :plus %></span>
      New collection
    </button>
  </div>

  <dialog class="cw-modal" data-dialog-target="dialog" data-action="click->dialog#backdrop">
    <div class="cw-modal__panel">
      <header class="cw-modal__head">
        <h2 class="cw-modal__title">New collection</h2>
        <button type="button" class="cw-modal__close" data-action="dialog#close" aria-label="Close">&times;</button>
      </header>
      <%= form_with url: collections_path, scope: :collection, method: :post, class: "cw-modal__body" do |f| %>
        <label class="cw-field">
          <span class="cw-field__label">Name</span>
          <%= f.text_field :name, placeholder: "e.g. Q3 Planning", class: "cw-input",
                required: true, data: { dialog_target: "field" } %>
        </label>
        <footer class="cw-modal__foot">
          <button type="button" class="cw-btn cw-btn--ghost" data-action="dialog#close">Cancel</button>
          <%= f.submit "Create", class: "cw-btn cw-btn--primary" %>
        </footer>
      <% end %>
    </div>
  </dialog>

  <% if @collections.empty? %>
    <p class="cw-empty">No collections yet. Create one to group related documents.</p>
  <% else %>
    <ul class="cw-doc-list">
      <% @collections.each do |collection| %>
        <li class="cw-doc-list__item">
          <%= link_to collection_path(collection), class: "cw-doc-list__row" do %>
            <span class="cw-doc-list__title"><%= icon :collection, class: "cw-doc-list__icon" %> <%= collection.display_name %></span>
            <span class="cw-doc-list__date"><%= pluralize(collection.documents.size, "doc") %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
