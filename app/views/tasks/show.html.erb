<div class="cw-page cw-page--wide">
  <% if notice = flash[:notice] %>
    <p class="cw-flash cw-flash--notice"><%= notice %></p>
  <% end %>

  <div class="cw-page__header cw-page__header--detail">
    <%= link_to tasks_path, class: "cw-back-link" do %>
      <%= icon :board %> Tasks
    <% end %>
    <%= button_to task_path(@task), method: :delete,
          form: { data: { turbo_confirm: "Delete this task?" } },
          class: "cw-btn cw-btn--danger" do %>
      Delete task
    <% end %>
  </div>

  <%= form_with url: task_path(@task), scope: :task, method: :patch, class: "task-edit" do |f| %>
    <%= f.text_field :title, value: @task.title, placeholder: Task::TITLE_FALLBACK,
          class: "cw-input cw-input--title task-edit__title", required: true %>
    <div class="task-edit__row">
      <%= f.select :status, Task::STATUSES.map { |s| [ Task::STATUS_LABELS[s], s ] },
            { selected: @task.status }, class: "cw-input task-edit__status" %>
      <%= f.submit "Save", class: "cw-btn cw-btn--primary" %>
    </div>
    <%= f.text_area :description, value: @task.description, rows: 5,
          placeholder: "Add a description…", class: "cw-input task-edit__description" %>
  <% end %>

  <section class="cw-section">
    <div class="cw-section__head"><h2 class="cw-section__title">Linked documents</h2></div>
    <% if @documents.any? %>
      <ul class="cw-doc-list">
        <% @documents.each do |document| %>
          <li class="cw-doc-list__item cw-doc-list__item--with-action">
            <%= link_to edit_document_path(document), class: "cw-doc-list__row" do %>
              <span class="cw-doc-list__title #{'cw-doc-list__title--untitled' if document.title.blank?}">
                <%= icon :document, class: "cw-doc-list__icon" %> <%= document.title.presence || "Untitled" %>
              </span>
              <span class="cw-doc-list__date"><%= document.updated_at.strftime("%b %-d") %></span>
            <% end %>
            <%= button_to task_document_path(@task, document), method: :delete,
                  class: "cw-row-remove", form_class: "cw-row-action",
                  title: "Unlink document", "aria-label": "Unlink document" do %>
              <%= icon :close %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="cw-empty">No documents linked yet.</p>
    <% end %>
    <% if @addable_documents.any? %>
      <%= form_with url: task_documents_path(@task), method: :post, class: "cw-picker" do |f| %>
        <%= f.select :document_id,
              @addable_documents.map { |d| [ d.title.presence || "Untitled", d.public_token ] },
              {}, class: "cw-input" %>
        <%= f.submit "Link", class: "cw-btn cw-btn--primary" %>
      <% end %>
    <% end %>
  </section>

  <section class="cw-section">
    <div class="cw-section__head"><h2 class="cw-section__title">Activity</h2></div>
    <% if @task.task_comments.any? %>
      <ul class="comment-list">
        <% @task.task_comments.each do |comment| %>
          <li class="comment <%= 'comment--agent' if comment.agent? %>">
            <div class="comment__head">
              <span class="comment__author"><%= comment.display_author %></span>
              <% if comment.agent? %><span class="comment__badge">agent</span><% end %>
              <span class="comment__time"><%= comment.created_at.strftime("%b %-d · %H:%M") %></span>
            </div>
            <div class="comment__body"><%= simple_format(comment.body) %></div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="cw-empty">No activity yet. An agent's comments will appear here.</p>
    <% end %>

    <%= form_with url: task_comments_path(@task), scope: :task_comment, method: :post, class: "comment-form" do |f| %>
      <%= f.text_area :body, rows: 2, placeholder: "Add a comment…", class: "cw-input comment-form__input" %>
      <%= f.submit "Comment", class: "cw-btn cw-btn--primary" %>
    <% end %>
  </section>
</div>
