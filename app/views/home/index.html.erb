<div class="mx-auto md:w-2/3 w-full py-12">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl mb-4">Clearwriter</h1>
  <p class="text-gray-600 mb-8">Signed in as <%= Current.user.email_address %>.</p>

  <%= button_to "Sign out", sign_out_path, method: :delete,
        class: "rounded-md px-3.5 py-2.5 bg-gray-200 hover:bg-gray-300 text-gray-900 inline-block font-medium cursor-pointer" %>
</div>
