<div class="cw-page"
     data-controller="copy-markdown"
     data-copy-markdown-url-value="<%= public_document_path(@document.public_token, format: :md) %>">
  <div class="cw-editor__bar">
    <span class="cw-editor__bar-spacer"></span>

    <details class="cw-menu">
      <summary class="cw-menu__trigger" aria-label="Document actions">⋯</summary>
      <div class="cw-menu__panel" role="menu">
        <button type="button"
                class="cw-menu__item"
                data-action="copy-markdown#copy">
          Copy as Markdown
        </button>
      </div>
    </details>
  </div>

  <article class="preview-host">
    <%= ClearwriterMarkdown.render(@document.body) %>
  </article>

  <footer style="margin-top: 64px; padding-top: 20px; border-top: 1px solid var(--cw-line); color: var(--cw-faint); font-size: 0.8rem; display: flex; align-items: center; justify-content: space-between;">
    <span>Made with <a href="/">Clearwriter</a></span>
    <span><%= @document.updated_at.strftime("%b %-d, %Y") %></span>
  </footer>
</div>
